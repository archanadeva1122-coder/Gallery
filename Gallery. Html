<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Image Gallery</title>

<style>
    body {
        font-family: Arial, sans-serif;
        margin: 0;
        padding: 20px;
        background-color: #f4f4f4;
    }

    h1 {
        text-align: center;
    }

    .gallery {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 15px;
    }

    .gallery img {
        width: 100%;
        height: 200px;
        object-fit: cover;
        border-radius: 10px;
        transition: transform 0.3s;
    }

    .gallery img:hover {
        transform: scale(1.05);
    }

    /* Mobile View */
    @media (max-width: 768px) {
        .gallery {
            grid-template-columns: 1fr;
        }
    }
</style>

</head>
<body>

<h1>My Image Gallery</h1>

<div class="gallery">
    <img src="https://source.unsplash.com/random/300x200?nature1">
    <img src="https://source.unsplash.com/random/300x200?nature2">
    <img src="https://source.unsplash.com/random/300x200?nature3">
    <img src="https://source.unsplash.com/random/300x200?nature4">
    <img src="https://source.unsplash.com/random/300x200?nature5">
    <img src="https://source.unsplash.com/random/300x200?nature6">
</div>

</body>
</html>

